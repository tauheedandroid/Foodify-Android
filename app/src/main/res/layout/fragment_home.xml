<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Title 1 -->
    <TextView
        android:id="@+id/tvFoods"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Foods"
        android:textColor="@color/black"
        android:textStyle="bold|italic"
        android:textSize="24sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- First RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFood"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="15dp"
        android:clipToPadding="false"
        android:paddingEnd="200dp"
        app:layout_constraintTop_toBottomOf="@id/tvFoods"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title 2 -->
    <TextView
        android:id="@+id/tvFastFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fast Foods"
        android:textColor="@color/black"
        android:textStyle="bold|italic"
        android:textSize="24sp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/rvFood"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Second RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFood2"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:paddingStart="16dp"
        android:paddingEnd="200dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvFastFood"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Title 3 -->
    <TextView
        android:id="@+id/tvCDFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cold Drinks"
        android:textColor="@color/black"
        android:textStyle="bold|italic"
        android:textSize="24sp"
        android:layout_marginTop="250dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/rvFood"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- third RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCD"
        android:layout_width="0dp"
        android:layout_height="250dp"
        android:layout_marginTop="250dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="200dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFastFood" />

    <TextView
        android:id="@+id/tvNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next→"
        android:textColor="@color/black"
        android:textStyle="bold|italic"
        android:textSize="24sp"
        android:layout_marginTop="740dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>